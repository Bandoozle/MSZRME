# Platform app URL (sign-in redirects). Local dev: platform runs on 3001.
NEXT_PUBLIC_PLATFORM_URL=http://localhost:3001

# Supabase (same project as platform/)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — website signup API (never expose to client)
SUPABASE_SERVICE_ROLE_KEY=
